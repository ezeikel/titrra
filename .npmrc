# Hoisted node_modules — required for the Expo/React Native app (apps/mobile)
# to resolve native modules via Metro inside a pnpm workspace.
node-linker=hoisted
shamefully-hoist=true
public-hoist-pattern=*

# Font Awesome Pro registry (shared FONTAWESOME_NPM_AUTH_TOKEN — pulled from
# Vercel env / shell, same as the other Chewy Bytes apps).
@fortawesome:registry=https://npm.fontawesome.com/
//npm.fontawesome.com/:_authToken=${FONTAWESOME_NPM_AUTH_TOKEN}
