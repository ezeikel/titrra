# App
EXPO_PUBLIC_ENVIRONMENT="development"
EXPO_PUBLIC_APP_URL="https://titrra.com"
# Local dev only. Production/preview should use EXPO_PUBLIC_APP_URL unless the API is split.
EXPO_PUBLIC_API_URL=""

# PostHog (same EU project as web)
EXPO_PUBLIC_POSTHOG_KEY=""
EXPO_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Sentry (org: chewybytes, project: titrra-app)
EXPO_PUBLIC_SENTRY_DSN=""
# Source map upload during EAS builds. Store as a secret; do not expose in app JS.
SENTRY_AUTH_TOKEN=""

# RevenueCat — public SDK keys (one per platform) from the RevenueCat dashboard
# (Project -> API keys -> "App-specific" Apple/Google keys). Empty = IAP
# disabled (configurePurchases no-ops). Entitlement id 'titrra_pro', offering
# 'default' with $rc_monthly / $rc_annual / $rc_lifetime packages — see
# lib/purchases.ts.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=""
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=""

# EAS project id (set after `eas init`)
EAS_PROJECT_ID=""
