# App
NEXT_PUBLIC_APP_URL="https://titrra.com"
DATABASE_URL=""
# Optional: only needed for drift checks / advanced migrate diff workflows.
SHADOW_DATABASE_URL=""

# PostHog (EU cloud — Chewy Bytes org at eu.posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=""
# Dev only — production routes through the /ingest reverse proxy (proxy.ts)
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Sentry (org: chewybytes, project: titrra-web)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Source map upload during build
SENTRY_AUTH_TOKEN=""

# Stripe (web Pro unlock)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Pro price ids (create in the Stripe dashboard: $7.99/mo, $39.99/yr, $59.99 lifetime)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_PRO_LIFETIME=""

# Resend (waitlist confirmation + transactional email)
RESEND_API_KEY=""
RESEND_EMAIL_DOMAIN="notifications.chewybytes.com"
RESEND_FROM="Titrra <hello@notifications.chewybytes.com>"

# Content worker (Hetzner box, Titrra = port 3070)
WORKER_URL="http://157.90.168.197:3070"
# Must match the worker's WORKER_SECRET.
WORKER_SECRET=""
# Vercel auto-sends this as `Authorization: Bearer <CRON_SECRET>` on cron hits.
CRON_SECRET=""

# Sanity (blog CMS, read-side — non-secret; write token lives on the worker)
NEXT_PUBLIC_SANITY_PROJECT_ID="5t3j0228"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-01-01"

# RevenueCat webhook (mobile IAP → DB). Static Authorization-header token set in
# the RevenueCat dashboard webhook config; the /api/revenuecat/webhook route
# checks it. Server-only.
REVENUECAT_WEBHOOK_AUTH_KEY=""
