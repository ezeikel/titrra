# --- HTTP server (Hetzner box) ---
# Port the Hono server binds (0.0.0.0). MUST be set explicitly on the box — the
# shared Hetzner runbook allocates 3070 to Titrra. See HETZNER_BOX.md.
PORT=3070
# Shared secret gating /generate/* + /publish/*. The web app / Vercel cron send
# it as `Authorization: Bearer <WORKER_SECRET>`. MUST match the web app's value.
# Unset = open (local dev only).
WORKER_SECRET=

# --- Database (shared Prisma client @titrra/db) ---
# Neon pooled URL. On the box this points at the PROD branch. Locally it can
# point at a dev branch. Neon project: delicate-bread-39347063.
DATABASE_URL=

# --- Anthropic (blog generation + social captions) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- OpenAI (social post image generation via gpt-image-2) ---
# https://platform.openai.com/api-keys — only needed for /generate/social.
OPENAI_API_KEY=

# --- Sanity (blog CMS write path) ---
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-01-01
# Write token (Editor role) — required for the worker to create draft posts.
SANITY_WRITE_TOKEN=

# --- Cloudflare R2 (hosts social images; FB fetches them by URL) ---
# Shared Chewy Bytes CF account. Buckets: titrra-dev / titrra-prod.
# On the box use the PROD bucket; R2_PUBLIC_URL there is the custom domain.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=titrra-prod
# Prod: https://assets.titrra.com   Dev: the pub-*.r2.dev managed URL.
R2_PUBLIC_URL=https://assets.titrra.com

# --- Facebook Page (social auto-posting) ---
# Numeric Page id + a LONG-LIVED Page access token (not a user token).
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- Sentry (error reporting) ---
# titrra-worker project DSN. Omit to disable reporting.
SENTRY_DSN=
