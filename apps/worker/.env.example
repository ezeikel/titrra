# --- HTTP server (Hetzner box) ---
# Port the Hono server binds (0.0.0.0). MUST be set explicitly on the box — the
# shared Hetzner runbook allocates 3070 to Titrra. See HETZNER_BOX.md.
PORT=3070
# Shared secret gating /generate/* + /publish/*. The web app / Vercel cron send
# it as `Authorization: Bearer <WORKER_SECRET>`. MUST match the web app's value.
# Unset = open (local dev only).
WORKER_SECRET=

# --- Database (shared Prisma client @titrra/db) ---
# Neon pooled URL. On the box this points at the PROD branch. Locally it can
# point at a dev branch. Neon project: delicate-bread-39347063.
DATABASE_URL=

# --- Anthropic (blog generation) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Sanity (blog CMS write path) ---
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-01-01
# Write token (Editor role) — required for the worker to create draft posts.
SANITY_WRITE_TOKEN=

# --- Sentry (error reporting) ---
# titrra-worker project DSN. Omit to disable reporting.
SENTRY_DSN=
