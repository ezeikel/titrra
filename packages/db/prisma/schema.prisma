generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Units {
  METRIC
  IMPERIAL
}

enum Drug {
  OZEMPIC
  WEGOVY
  MOUNJARO
  ZEPBOUND
  RYBELSUS
  COMPOUNDED_SEMAGLUTIDE
  COMPOUNDED_TIRZEPATIDE
  OTHER
}

enum MedicationForm {
  INJECTION
  ORAL
}

enum ScheduleType {
  WEEKLY
  DAILY
}

// Injection-site rotation map. Left/right of the three canonical sites — the
// app suggests the next site to avoid overuse (signature feature).
enum InjectionSite {
  ABDOMEN_L
  ABDOMEN_R
  THIGH_L
  THIGH_R
  ARM_L
  ARM_R
}

enum WeightUnit {
  KG
  LB
}

// Which body figure to show on the 3D injection-site map. Framed as a visual
// preference ("body shape"), not a clinical/identity field. UNSPECIFIED = the
// neutral default when the user skips.
enum BodyShape {
  MALE
  FEMALE
  UNSPECIFIED
}

enum SideEffectType {
  NAUSEA
  CONSTIPATION
  DIARRHEA
  FATIGUE
  REFLUX
  HEADACHE
  INJECTION_SITE_REACTION
  OTHER
}

enum ReminderType {
  DOSE
  PILL
  WEIGH_IN
  PROTEIN
  WATER
}

// ─── Billing enums ───────────────────────────────────────────────────────────

// Which provider a subscription row came from. Both write to the same
// Subscription table, keyed to the same User — the DB is the source of truth.
enum SubscriptionPlatform {
  STRIPE
  REVENUECAT
}

// Titrra is single-tier (titrra_pro), so plan = the billing period. LIFETIME is
// a one-time non-consumable that grants access with no renewal.
enum BillingPeriod {
  MONTHLY
  ANNUAL
  LIFETIME
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  PAUSED
  INCOMPLETE
  UNPAID
}

// Append-only audit log event types — one row per meaningful billing event so
// cross-provider bugs are debuggable.
enum SubscriptionEventType {
  TRIAL_STARTED
  SUBSCRIPTION_STARTED
  RENEWAL_SUCCESS
  RENEWAL_FAILED
  CANCELLATION_SCHEDULED
  CANCELLED
  REACTIVATED
  BILLING_ISSUE_DETECTED
  EXPIRED
  TRANSFERRED
  REFUNDED
}

// ─── Models ──────────────────────────────────────────────────────────────────

// Anonymous-first: email is nullable so a user can track without an account and
// claim later. Entitlement is the DB source of truth: both Stripe (web) and
// RevenueCat (mobile) attach subscriptions to this same User.id, and
// "is Pro now?" is computed from the Subscription rows (no denormalised flag).
model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  healthSyncEnabled Boolean   @default(false)
  units             Units     @default(METRIC)
  bodyShape         BodyShape @default(UNSPECIFIED)
  // Provider linkage (the entitlement itself lives in Subscription).
  stripeCustomerId  String?
  revenuecatUserId  String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  medications    Medication[]
  weightLogs     WeightLog[]
  sideEffectLogs SideEffectLog[]
  intakeLogs     IntakeLog[]
  reminders      Reminder[]
  subscriptions  Subscription[]

  @@map("users")
}

model Medication {
  id           String         @id @default(cuid())
  userId       String
  drug         Drug
  form         MedicationForm
  scheduleType ScheduleType
  startedAt    DateTime       @default(now())
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  titrationSteps TitrationStep[]
  doseLogs       DoseLog[]
  reminders      Reminder[]

  @@index([userId, active])
  @@map("medications")
}

// The namesake feature: the dose-escalation ladder (e.g. 2.5 → 5 → 7.5 → 10mg).
// `order` sequences the rungs; planned vs actual start dates drive the
// "time to step up" reminders and the provider-consult prompts.
model TitrationStep {
  id               String    @id @default(cuid())
  medicationId     String
  doseMg           Float
  order            Int
  plannedStartDate DateTime?
  actualStartDate  DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@unique([medicationId, order])
  @@index([medicationId, order])
  @@map("titration_steps")
}

// One-tap "logged today's shot". `injectionSite` is nullable for oral meds and
// feeds the rotation-map suggestion. `skipped` records an intentionally missed
// dose without inventing a fake takenAt.
model DoseLog {
  id            String         @id @default(cuid())
  medicationId  String
  takenAt       DateTime       @default(now())
  doseMg        Float
  injectionSite InjectionSite?
  skipped       Boolean        @default(false)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId, takenAt(sort: Desc)])
  @@map("dose_logs")
}

// Quick weight entry + trend line. `photoUrl` is the optional progress photo
// (Pro). Injection-site rotation state is DERIVED from DoseLog history, not
// stored — there is intentionally no InjectionSite table.
model WeightLog {
  id         String     @id @default(cuid())
  userId     String
  recordedAt DateTime   @default(now())
  weight     Float
  unit       WeightUnit
  photoUrl   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt(sort: Desc)])
  @@map("weight_logs")
}

model SideEffectLog {
  id         String         @id @default(cuid())
  userId     String
  occurredAt DateTime       @default(now())
  type       SideEffectType
  // 1–5 severity (validated in app code — Postgres has no native range check
  // we set here; keep the contract in the type layer).
  severity   Int
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([userId, type])
  @@map("side_effect_logs")
}

// Protein / water nudges (Pro). One row per user per day; `date` is YYYY-MM-DD
// in the user's local calendar so the daily aggregate is stable across tz.
model IntakeLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  proteinG  Float?
  waterMl   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("intake_logs")
}

// Local-notification schedule. `medicationId` is nullable for non-med
// reminders (weigh-in / protein / water). `schedule` holds the cron-ish or
// ISO recurrence string the client uses to register expo-notifications.
model Reminder {
  id           String       @id @default(cuid())
  userId       String
  medicationId String?
  type         ReminderType
  schedule     String
  enabled      Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication Medication? @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@index([medicationId])
  @@map("reminders")
}

// Pre-launch waitlist capture from the marketing/landing page. Mirrors the
// chunky-crayon EmailSubscriber pattern (DB-persisted, dedup on email, capture
// the source surface), but right-sized: Titrra has a single waitlist surface,
// so no per-list/brand machinery. `email` is unique so a re-submit upserts
// instead of duplicating. `source` is free-form ('landing-hero', 'footer', …).
model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("waitlist")
}

// ─── Billing (DB = entitlement source of truth) ──────────────────────────────

// One row per subscription per platform. "Is this user Pro right now?" is
// computed from these rows (status ACTIVE/TRIALING, or PAST_DUE within grace,
// or CANCELLED before currentPeriodEnd) — never stored as a boolean. Both the
// Stripe and RevenueCat webhooks write here, discriminated by `platform`.
model Subscription {
  id                   String               @id @default(cuid())
  userId               String
  platform             SubscriptionPlatform @default(STRIPE)
  // Stripe subscription id OR the RC event/transaction id — unique per provider.
  externalId           String               @unique
  // Kept for the Stripe customer.subscription.* webhook lookups.
  stripeSubscriptionId String?              @unique
  billingPeriod        BillingPeriod
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelledAt          DateTime?
  gracePeriodEnd       DateTime?
  // e.g. "titrra_pro_monthly_v1" — the store product id.
  storeProductId       String?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events SubscriptionEvent[]

  @@index([userId])
  @@index([platform, externalId])
  @@map("subscriptions")
}

// Append-only audit log so a cross-provider entitlement bug is debuggable.
model SubscriptionEvent {
  id              String                @id @default(cuid())
  subscriptionId  String?
  userId          String
  eventType       SubscriptionEventType
  platform        SubscriptionPlatform
  // Provider event id, deduped so retried webhooks don't double-log.
  externalEventId String?               @unique
  previousStatus  SubscriptionStatus?
  newStatus       SubscriptionStatus?
  rawPayload      Json?
  createdAt       DateTime              @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@map("subscription_events")
}

// Idempotency guard for the RevenueCat webhook (keyed on the RC event id).
model WebhookEvent {
  id          String               @id
  platform    SubscriptionPlatform
  eventType   String
  processedAt DateTime             @default(now())

  @@map("webhook_events")
}

// Idempotency guard for the Stripe webhook (keyed on the Stripe event id).
model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@map("stripe_webhook_events")
}
